# Supabase — required for form submissions + newsletter.
# Create a project at https://supabase.com, then copy these from
# Project Settings → API. Duplicate this file to `.env.local` and fill in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key, used by route handlers to insert rows past RLS.
# Project Settings → API → service_role. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Where form notifications should be sent (informational; wire your ESP).
CONTACT_NOTIFICATION_EMAIL=tony@davinciconsultingservices.com

# Anthropic (Claude) — powers the on-site AI assistant ("Leo") at /api/chat.
# Create a key at https://console.anthropic.com → Settings → API Keys.
# Server-only; never expose to the client. Without it, the chat widget still
# renders and politely directs visitors to call/contact the team.
ANTHROPIC_API_KEY=
